  },
  "devDependencies": {
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^6.0.0",
    "concurrently": "^7.6.0",
    "typescript": "^5.0.0",
    "vite": "^8.0.0",
    "vitest": "^1",
    "wrangler": "^4.104.0"
  }
}
